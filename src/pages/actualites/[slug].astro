---
import Layout from '../../layouts/Layout.astro';
import { news } from '../../data/news';
import StrapiBlocks from '../../components/StrapiBlocks.astro';

export async function getStaticPaths() {
  return news.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<Layout title={`${item.title} | Luthier Artisan`}>
    <article class="news-detail">
        <header class="hero-header">
            <div class="header-content">
                <div class="container">
                    <div class="breadcrumb">
                        <a href="/actualites">← Retour aux actualités</a>
                    </div>
                    <span class="date">{new Date(item.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                    <h1>{item.title}</h1>
                </div>
            </div>
            <div class="hero-image">
                <img src={item.image} alt={item.title} />
            </div>
        </header>

        <div class="container content-wrapper">
            <div class="main-content">
                <StrapiBlocks content={item.content} />
            </div>
        </div>
    </article>
</Layout>

<style>
    .news-detail {
        padding-bottom: 5rem;
        background-color: white;
    }
    .hero-header {
        position: relative;
        min-height: 500px;
        display: flex;
        align-items: center;
        margin-bottom: 4rem;
        padding-top: 100px;
    }
    .hero-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }
    .hero-image::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(20, 13, 14, 0.7), rgba(20, 13, 14, 0.4));
    }
    .hero-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .header-content {
        position: relative;
        z-index: 2;
        color: white;
        width: 100%;
    }
    .container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }
    .breadcrumb {
        margin-bottom: 2rem;
    }
    .breadcrumb a {
        color: var(--oak-wood);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    .breadcrumb a:hover {
        text-decoration: underline;
    }
    .date {
        display: block;
        color: var(--oak-wood);
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 1rem;
    }
    h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        color: white;
        line-height: 1.2;
    }
    .content-wrapper {
        margin-top: -2rem;
        position: relative;
        z-index: 3;
    }
    .main-content {
        background: white;
        padding: 4rem;
        border-radius: 4px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    }
    
    @media (max-width: 768px) {
        .hero-header {
            min-height: 400px;
        }
        .main-content {
            padding: 2rem;
        }
        h1 {
            font-size: 2rem;
        }
    }
</style>
