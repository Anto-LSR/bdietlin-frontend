---
import { getImage } from 'astro:assets';
import heroBg from '../assets/images/image_123650291.JPG';

const optimizedHero = await getImage({ src: heroBg, format: 'webp', width: 1920 });
---
<section class="hero" style={`background: linear-gradient(rgba(20, 13, 14, 0.5), rgba(20, 13, 14, 0.5)), url(${optimizedHero.src}) center/cover no-repeat fixed;`}>
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h1>Guitares sur mesure</h1>
        <p>Chaque instrument raconte une histoire. Chaque note porte l'âme du bois et la main de l'artisan.</p>
        <a href="/instruments" class="btn">Découvrir la Collection</a>
    </div>
</section>
