---
import logo from '../assets/logo.svg';  // Astro optimise automatiquement (webp, lazy...)
---


<header>
    <nav class="container">
        <div class="icon_and_text" style="display: flex; align-items: center;">
            <a href="/" class="logo-link flex items-center gap-3 hover:no-underline">
                <img src={logo.src} alt="Logo Benjamin Dietlin Lutherie"
                     width={100} height={100} class="logo-svg"
                     loading="eager"/>
            </a>
            <a><span class="logo-text text-2xl font-serif">Benjamin Dietlin Lutherie</span></a>
        </div>
        <ul>
            <li><a href="#instruments">Instruments</a></li>
            <li><a href="#services">Services</a></li>
            <li><a href="#news">Actualités</a></li>
            <li><a href="#news">Expositions</a></li>
        </ul>
    </nav>
</header>

<style>
    .logo-link {
        color: #2c1810;
        transition: color 0.3s;
    }

    .logo-link:hover {
        color: #d4a574;
    }

    .logo-svg {
        flex-shrink: 0;
        filter: drop-shadow(1px 1px 2px rgba(44, 24, 16, 0.3));
    }

    @media (max-width: 768px) {
        .logo-text {
            font-size: 1.5rem;
        }

        .logo-svg {
            width: 40px;
            height: 40px;
        }
    }
</style>
