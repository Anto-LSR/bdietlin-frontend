---
import logo from '../assets/logo.svg';  // Astro optimise automatiquement (webp, lazy...)
---


<header>
    <nav class="container">
        <a href="/" class="logo-link">
            <img src={logo.src} alt="Logo Benjamin Dietlin Lutherie"
                 width={100} height={100} class="logo-svg"
                 loading="eager"/>
            <span class="logo-text">Benjamin Dietlin Lutherie</span>
        </a>
        <ul>
            <li><a href="/instruments">Instruments</a></li>
            <li><a href="/actualites">Actualités</a></li>
            <li><a href="/expositions">Expositions</a></li>
            <li><a href="/#services">Prestations</a></li>
            <li><a href="/about">À propos</a></li>
        </ul>
    </nav>
</header>

<script>
    const header = document.querySelector('header');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            header?.classList.add('scrolled');
        } else {
            header?.classList.remove('scrolled');
        }
    }, { passive: true });
</script>

<style>
    .logo-link {
        display: flex;
        align-items: center;
        text-decoration: none;
        transition: var(--transition-smooth);
    }

    .logo-text {
        font-family: 'Playfair Display', serif;
        font-size: 1.3rem;
        font-weight: 400;
        color: var(--oak-wood);
        transition: var(--transition-smooth);
        white-space: nowrap;
        margin-left: 1rem;
        overflow: hidden;
        max-width: 400px;
    }

    .logo-svg {
        height: 60px;
        width: auto;
        flex-shrink: 0;
        filter: drop-shadow(1px 1px 2px rgba(44, 24, 16, 0.3));
        transition: var(--transition-smooth);
    }

    .logo-link:hover .logo-text {
        color: var(--chocolate-brown);
    }

    /* Styles pour l'état scrollé (gérés via la classe ajoutée en JS) */
    @media (min-width: 769px) {
        :global(header.scrolled) .logo-text {
            opacity: 0;
            max-width: 0;
            margin-left: 0;
            pointer-events: none;
        }
    }

    :global(header.scrolled) .logo-svg {
        height: 40px;
    }

    @media (max-width: 768px) {
        .logo-text {
            font-size: 1.1rem;
        }

        .logo-svg {
            width: 35px;
            height: 35px;
        }
    }
</style>
